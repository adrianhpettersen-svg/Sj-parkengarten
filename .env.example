# Resend (transactional e-post for kontaktskjema)
# Hent fra https://resend.com/api-keys etter at du har verifisert sjoparkengarten.no
RESEND_API_KEY=

# Avsenderadresse — må være på et domene verifisert i Resend
# Eksempel: "Sjøparken Garten <noreply@sjoparkengarten.no>"
RESEND_FROM=

# Hvor skjema-meldinger skal sendes (defaulter til site.contact.email = post@sjoparkengarten.no)
CONTACT_TO=
